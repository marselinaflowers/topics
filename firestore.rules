rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function validTopicText(value) {
      return value is string && value.size() > 0 && value.size() <= 50;
    }

    function validDisplayName(value) {
      return value is string && value.size() > 0 && value.size() <= 32;
    }

    match /topics/{topicId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'text',
          'authorUid',
          'authorDisplayName',
          'createdAt',
        ])
        && request.resource.data.authorUid == request.auth.uid
        && validTopicText(request.resource.data.text)
        && validDisplayName(request.resource.data.authorDisplayName);

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
