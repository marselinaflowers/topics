rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validUsername(name) {
      return name is string
        && name.size() >= 3
        && name.size() <= 32
        && name.matches('^[A-Za-z0-9_]+$');
    }

    function validNormalizedUsername(name) {
      return name is string
        && name.size() >= 3
        && name.size() <= 32
        && name.matches('^[a-z0-9_]+$');
    }

    match /usernames/{normalizedName} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['uid', 'username', 'normalized', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && validNormalizedUsername(request.resource.data.username)
        && validNormalizedUsername(request.resource.data.normalized)
        && request.resource.data.username == request.resource.data.normalized
        && normalizedName == request.resource.data.normalized;

      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
